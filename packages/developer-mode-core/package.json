{
  "name": "@viscalyx/developer-mode-core",
  "version": "0.2.2",
  "description": "Framework-agnostic developer mode utilities and marker helpers",
  "license": "MIT",
  "author": "Viscalyx",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./noop": {
      "types": "./dist/noop.d.ts",
      "import": "./dist/noop.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc -b",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viscalyx/developer-mode.git",
    "directory": "packages/developer-mode-core"
  },
  "homepage": "https://github.com/viscalyx/developer-mode/tree/main/packages/developer-mode-core#readme",
  "bugs": {
    "url": "https://github.com/viscalyx/developer-mode/issues"
  },
  "keywords": [
    "developer-mode",
    "debugging",
    "overlay",
    "ui-debug"
  ]
}
